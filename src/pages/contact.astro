---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHead from '@components/ui/SectionHead.astro';
---

<BaseLayout title="Contact" description="Cara menghubungi saya.">
  <div class="page-shell">
    <header class="page-header animate-fade-up">
      <SectionHead number="05" label="CONTACT" />
      <p class="page-desc">
        Tidak ada form yang rumit. Kalau mau ngobrol, pilih channel yang paling nyaman.
      </p>
    </header>

    <div class="contact-grid animate-fade-up delay-2">
      <!-- Email -->
      <a href="mailto:hi@terces.dev" class="contact-card">
        <div class="card-accent"></div>
        <span class="card-icon" aria-hidden="true">✉</span>
        <div class="card-body">
          <span class="card-label">Email</span>
          <span class="card-value">hi@terces.dev</span>
          <span class="card-note">Respons dalam 1–2 hari.</span>
        </div>
        <span class="card-arrow" aria-hidden="true">→</span>
      </a>

      <!-- GitHub -->
      <a href="https://github.com/terces" target="_blank" rel="noopener" class="contact-card">
        <div class="card-accent"></div>
        <span class="card-icon" aria-hidden="true">⌥</span>
        <div class="card-body">
          <span class="card-label">GitHub</span>
          <span class="card-value">@terces</span>
          <span class="card-note">Source code & project activity.</span>
        </div>
        <span class="card-arrow" aria-hidden="true">↗</span>
      </a>

      <!-- Twitter/X -->
      <a href="https://twitter.com/terces" target="_blank" rel="noopener" class="contact-card">
        <div class="card-accent"></div>
        <span class="card-icon" aria-hidden="true">✕</span>
        <div class="card-body">
          <span class="card-label">Twitter / X</span>
          <span class="card-value">@terces</span>
          <span class="card-note">Pikiran acak dan update proyek.</span>
        </div>
        <span class="card-arrow" aria-hidden="true">↗</span>
      </a>
    </div>

    <!-- Note -->
    <aside class="contact-note animate-fade-up delay-3">
      <span class="note-prefix" aria-hidden="true">// </span>
      Saya tidak aktif di semua platform sekaligus. Email adalah yang paling reliabel.
      Kalau tentang post di blog atau proyek, mention konteksnya biar lebih mudah dilanjutkan.
    </aside>
  </div>
</BaseLayout>

<style>
.page-shell  { padding: 56px 44px 80px; max-width: 720px; }
.page-header { margin-bottom: 40px; }
.page-desc   { font-size: var(--text-base); color: var(--text-muted); max-width: 500px; line-height: 1.7; margin: -8px 0 0; }

.contact-grid {
  display: flex; flex-direction: column; gap: 14px;
  margin-bottom: 36px;
}
.contact-card {
  display: flex; align-items: center; gap: 18px;
  padding: 22px;
  background: var(--color-navy);
  border-radius: var(--radius-sm);
  text-decoration: none; color: inherit;
  position: relative; overflow: hidden;
  transition: transform var(--dur-base), box-shadow var(--dur-base);
}
.contact-card:hover { transform: translateX(6px); box-shadow: 0 4px 20px rgba(0,0,0,.3); }
.card-accent {
  position: absolute; top: 0; bottom: 0; left: 0; width: 3px;
  background: var(--color-cyan); transform: scaleY(0); transform-origin: top;
  transition: transform .3s var(--ease-out-cubic);
}
.contact-card:hover .card-accent { transform: scaleY(1); }

.card-icon {
  font-size: 22px; color: var(--color-cyan);
  width: 36px; text-align: center; flex-shrink: 0;
}
.card-body   { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.card-label  { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); letter-spacing: .08em; }
.card-value  { font-family: var(--font-display); font-weight: 600; font-size: var(--text-base); color: var(--color-white); }
.card-note   { font-size: var(--text-sm); color: var(--text-muted); }
.card-arrow  { font-size: 18px; color: var(--text-muted); transition: color var(--dur-fast), transform var(--dur-fast); }
.contact-card:hover .card-arrow { color: var(--color-cyan); transform: translateX(4px); }

.contact-note {
  font-family: var(--font-mono); font-size: var(--text-sm);
  color: var(--text-muted); line-height: 1.7;
  padding: 18px 20px;
  background: rgba(81,238,252,.04);
  border: 1px solid rgba(81,238,252,.1);
  border-radius: var(--radius-sm);
}
.note-prefix { color: var(--color-cyan); }

@media (max-width: 600px) {
  .page-shell { padding: 36px 20px 60px; }
}
</style>
