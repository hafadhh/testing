---
// Floating top-right bar: search + theme toggle.
// Hides on scroll down, reappears on scroll up — matching zenCipher behavior.
---

<div class="topbar" id="topbar">
  <button class="tb-btn tb-search " data-action="search" aria-label="Search">
    <div class="tb-flash" aria-hidden="true"></div>
    <svg class="icon-default" viewBox="0 0 24 24" aria-hidden="true">
      <circle class="glyph" cx="10.5" cy="10.5" r="6.5"/>
      <line class="glyph" x1="15.5" y1="15.5" x2="21" y2="21"/>
    </svg>
    <svg class="icon-hover" viewBox="0 0 24 24" aria-hidden="true">
      <circle class="glyph" cx="10.5" cy="10.5" r="6.5" fill="rgba(81,238,252,.18)" stroke-width="2"/>
      <line class="glyph" x1="15.5" y1="15.5" x2="21" y2="21" stroke-width="2.4"/>
    </svg>
  </button>

  <button class="tb-btn tb-theme" data-action="theme" aria-label="Toggle theme" id="themeToggle">
    <div class="tb-flash" aria-hidden="true"></div>
    <svg class="icon-default" viewBox="0 0 24 24" aria-hidden="true">
      <circle class="glyph" cx="12" cy="12" r="7"/>
      <path class="glyph" d="M12 5 a7 7 0 0 0 0 14 z" fill="currentColor" stroke="none"/>
    </svg>
    <svg class="icon-hover" viewBox="0 0 24 24" aria-hidden="true">
      <circle class="glyph" cx="12" cy="12" r="7" fill="rgba(81,238,252,.22)" stroke-width="2"/>
      <line class="glyph" x1="12" y1="2" x2="12" y2="4" stroke-width="2"/>
      <line class="glyph" x1="12" y1="20" x2="12" y2="22" stroke-width="2"/>
      <line class="glyph" x1="2" y1="12" x2="4" y2="12" stroke-width="2"/>
      <line class="glyph" x1="20" y1="12" x2="22" y2="12" stroke-width="2"/>
    </svg>
  </button>
</div>

<style>
.topbar {
  position: fixed;
  top: 22px; right: 28px;
  z-index: var(--z-overlay);
  display: flex;
  gap: 10px;
  transition: transform .35s var(--ease-out-cubic), opacity .3s ease;
}
.topbar.hidden {
  transform: translateY(-140%);
  opacity: 0;
  pointer-events: none;
}

.tb-btn {
  width: 38px; height: 38px;
  border-radius: 4%;
  background: rgba(0,24,62,.7);
  border: 1px solid rgba(81,238,252,.2);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  display: flex; align-items: center; justify-content: center;
  position: relative;
  transition: transform .2s var(--ease-out-cubic),
              border-color .2s, background .2s;
}
.tb-btn:hover {
  transform: scale(1.1) rotate(-11deg);
  border-color: var(--color-cyan);
  background: rgba(245, 245, 245, 0.9);
  border: 1px solid rgba(218, 32, 32, 0.9);
}

.tb-btn svg { width: 16px; height: 16px; position: absolute; }
.tb-btn svg .glyph { stroke: var(--text-muted); fill: none; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
.tb-btn svg.icon-hover .glyph { stroke: var(--color-cyan); }
.tb-btn svg.icon-hover { display: none; }
.tb-btn:hover svg.icon-default { display: none; }
.tb-btn:hover svg.icon-hover   { display: block; }

.tb-flash {
  position: absolute; inset: -3px; border-radius: 50%;
  background: var(--color-cyan); opacity: 0; pointer-events: none;
}
.tb-btn.flash .tb-flash { animation: tbFlash .35s ease-out; }
@keyframes tbFlash {
  from { opacity: .5; transform: scale(.7); }
  to   { opacity: 0;  transform: scale(1.3); }
}

@media (max-width: 768px) {
  .topbar { top: 16px; right: 16px; }
}
</style>

<script>
const topbar = document.getElementById('topbar')!;
let lastY = window.scrollY;
let ticking = false;

function onScroll() {
  const y = window.scrollY;
  const goingDown = y > lastY;
  const pastThreshold = y > 80;

  if (goingDown && pastThreshold) {
    topbar.classList.add('hidden');
  } else {
    topbar.classList.remove('hidden');
  }
  lastY = y;
  ticking = false;
}

window.addEventListener('scroll', () => {
  if (!ticking) {
    requestAnimationFrame(onScroll);
    ticking = true;
  }
}, { passive: true });

// Click flash feedback
document.querySelectorAll<HTMLElement>('.tb-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    btn.classList.remove('flash');
    void btn.offsetWidth;
    btn.classList.add('flash');
  });
});
</script>
