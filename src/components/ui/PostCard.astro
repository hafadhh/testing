---
import Tag from './Tag.astro';
import { formatDateShort } from '@utils/content';
interface Props {
  title: string;
  description: string;
  slug: string;
  publishDate: Date;
  tags: string[];
  index?: number;
}
const { title, description, slug, publishDate, tags, index = 0 } = Astro.props;
---
<article class="post-card reveal-item" style={`animation-delay:${index * 80}ms`}>
  <a href={`/blog/${slug}`} class="post-link" aria-label={title}>
    <div class="post-accent"></div>
    <div class="post-meta">
      <time class="post-date" datetime={publishDate.toISOString()}>
        {formatDateShort(publishDate)}
      </time>
    </div>
    <h3 class="post-title">{title}</h3>
    <p class="post-desc">{description}</p>
    <div class="post-tags">
      {tags.slice(0, 3).map(t => <Tag label={t} />)}
    </div>
  </a>
</article>
<style>
.post-card {
  background: var(--color-navy);
  border-radius: var(--radius-sm);
  position: relative;
  opacity: 0;
  transform: translateY(16px);
}
.post-card.visible {
  opacity: 1;
  transform: translateY(0);
  transition: opacity .4s ease, transform .4s var(--ease-out-cubic);
}
.post-link {
  display: block;
  padding: 22px;
  text-decoration: none;
}
.post-accent {
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--color-cyan);
  transform: scaleX(0); transform-origin: left;
  transition: transform .3s var(--ease-out-cubic);
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
}
.post-card:hover .post-accent { transform: scaleX(1); }
.post-card:hover { box-shadow: 0 6px 28px rgba(0,0,0,.35); }
.post-meta { margin-bottom: 8px; }
.post-date {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--color-cyan);
  letter-spacing: .06em;
}
.post-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: var(--text-lg);
  color: var(--color-white);
  margin: 0 0 8px;
  line-height: 1.3;
  transition: color var(--dur-fast);
}
.post-card:hover .post-title { color: var(--color-cyan); }
.post-desc {
  font-size: var(--text-sm);
  color: var(--text-muted);
  line-height: 1.6;
  margin: 0 0 14px;
}
.post-tags { display: flex; gap: 6px; flex-wrap: wrap; }
</style>
